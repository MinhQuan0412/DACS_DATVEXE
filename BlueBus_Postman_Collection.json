  "item": [
    {
      "name": "🔓 PUBLIC - Không cần token",
      "item": [
        {
          "name": "AUTH - Gửi OTP",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/send-otp",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"soDienThoai\": \"0999888777\"\n}"}
          }
        },
        {
          "name": "AUTH - Đăng ký",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/register",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"soDienThoai\": \"0999888777\",\n  \"otp\": \"123456\",\n  \"hoTen\": \"Nguyễn Văn Test\",\n  \"email\": \"test@gmail.com\",\n  \"matKhau\": \"123456\",\n  \"xacNhanMatKhau\": \"123456\"\n}"}
          }
        },
        {
          "name": "AUTH - Đăng nhập User",
          "request": {
