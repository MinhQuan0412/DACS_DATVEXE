            "body": {"mode":"raw","raw":"{\n  \"content\": \"VE-1779454850890\",\n  \"amount\": 250000,\n  \"transfer_type\": \"in\",\n  \"reference_code\": \"TXN123456\",\n  \"id\": \"TXN123456\"\n}"}
          }
        },
        {
          "name": "BOOKINGS - Tra cứu vé (không login)",
