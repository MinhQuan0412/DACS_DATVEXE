          }
        },
        {
          "name": "AUTH - Đặt lại mật khẩu",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/reset-password",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"soDienThoai\": \"0912345678\",\n  \"otp\": \"123456\",\n  \"matKhauMoi\": \"newpass123\",\n  \"xacNhanMatKhauMoi\": \"newpass123\"\n}"}
          }
        },
        {
          "name": "AUTH - Lấy Captcha",
          "request": { "method": "GET", "url": "{{base_url}}/api/auth/captcha" }
